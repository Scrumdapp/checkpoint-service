#
# Scrumdapp readme, these are all the values needed for the app to launch
#

#
# Database credentials
#

# The database driver to use, postgres recomended
DATABASE_DRIVER=org.postgresql.Driver

# Other database data...
DATABASE_URL=jdbc:postgresql://localhost:5432/scrumdapp
DATABASE_USER=scrumdapp
DATABASE_PASSWORD=scrumdapp
JWK-SET-URI=http://localhost:9999/.well-known/jwks.json

GROUP_SERVICE_URL=http://localhost:3000

APPLICATION_PORT=3000